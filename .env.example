# --- Postgres -----------------------------------------------------------------
# Async URL — note the +asyncpg driver. Required for SQLAlchemy 2.x async engine.
# For host-side runs (alembic, pytest), point at localhost.
# Inside docker-compose, the crawler container overrides host=postgres (see compose file).
DATABASE_URL=postgresql+asyncpg://trend:trend@localhost:5432/trend_researcher

# --- Crawler ------------------------------------------------------------------
# Top-N items pulled per source per run. CLI flag --top-n/-n overrides.
CRAWLER_TOP_N=100

# Log output format: "json" (default, prod) or "text" (dev console).
LOG_FORMAT=json
